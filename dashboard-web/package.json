		"@rsbuild/plugin-react": "^1.4.2",
		"@tailwindcss/postcss": "^4.1.18",
		"@types/bun": "^1.3.10",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@types/ws": "^8.18.1",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3"
	},
	"workspaces": {
		"packages": [
			"api"
		]
